{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "source .env 2>/dev/null; curl -s -X POST \"https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage\" -d \"chat_id=$TELEGRAM_CHAT_ID&text=%F0%9F%9F%A1+Claude+session+started\" > /dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || git commit -m \"auto: apply changes\"; git push origin main 2>&1 || true",
            "statusMessage": "Pushing all changes to GitHub..."
          },
          {
            "type": "command",
            "command": "source .env 2>/dev/null; curl -s -X POST \"https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage\" -d \"chat_id=$TELEGRAM_CHAT_ID&text=%E2%9C%85+Claude+finished+and+pushed+to+GitHub\" > /dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git add -A && git diff --cached --quiet || git commit -m \"$(git diff --cached --name-only | head -3 | sed 's|.*/||' | sed 's/\\.[^.]*$//' | paste -sd ', ' -)$([ $(git diff --cached --name-only | wc -l) -gt 3 ] && echo ' +more'): update\"",
            "statusMessage": "Committing changes..."
          }
        ]
      }
    ]
  }
}
