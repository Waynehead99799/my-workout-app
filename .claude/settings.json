{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "source .env 2>/dev/null; curl -s -X POST \"https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage\" -d \"chat_id=$TELEGRAM_CHAT_ID&text=%F0%9F%9F%A1+Claude+session+started\" > /dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git checkout -B claude 2>/dev/null; node scripts/smart-commit.js && git push origin claude 2>&1 || true",
            "statusMessage": "Committing and pushing to claude branch..."
          },
          {
            "type": "command",
            "command": "source .env 2>/dev/null; curl -s -X POST \"https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage\" -d \"chat_id=$TELEGRAM_CHAT_ID&text=%E2%9C%85+Claude+finished+and+pushed+to+GitHub\" > /dev/null 2>&1 || true",
            "async": true
          }
        ]
      }
    ]
  }
}
